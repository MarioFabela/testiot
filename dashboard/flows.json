[
    {
        "id": "mqtt_broker_local",
        "type": "mqtt-broker",
        "name": "Mosquitto Docker",
        "broker": "mosquitto",
        "port": "1883",
        "clientid": "NodeRED_Dashboard",
        "usetls": false,
        "protocolVersion": "4",
        "keepalive": "60",
        "cleansession": true
    },
    {
        "id": "tab_dashboard",
        "type": "ui_tab",
        "name": "Clasificador ESCOM",
        "icon": "dashboard",
        "order": 1
    },
    {
        "id": "group_estado",
        "type": "ui_group",
        "name": "Estado del Sistema",
        "tab": "tab_dashboard",
        "order": 1,
        "disp": true,
        "width": "6"
    },
    {
        "id": "mqtt_in_color",
        "type": "mqtt in",
        "name": "Recibir Color",
        "topic": "escom/6CM3/equipo_clasificador/sensor/color",
        "qos": "1",
        "datatype": "utf8",
        "broker": "mqtt_broker_local",
        "x": 170,
        "y": 140,
        "wires": [
            [
                "ui_text_color"
            ]
        ]
    },
    {
        "id": "ui_text_color",
        "type": "ui_text",
        "name": "Mostrar Color",
        "group": "group_estado",
        "order": 1,
        "width": 0,
        "height": 0,
        "label": "Último Objeto Detectado:",
        "format": "{{msg.payload}}",
        "layout": "row-center",
        "x": 450,
        "y": 140,
        "wires": []
    }
]